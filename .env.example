# ==============================================
# NEXORA SURVEY — Environment Variables
# ==============================================
# These MUST be set in Netlify Dashboard:
#   Site Settings → Environment Variables
# After adding/changing, redeploy the site!
# ==============================================

# Supabase Project URL (from Supabase → Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (from Supabase → Settings → API → Project API Keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...your-anon-key

# Supabase Service Role Key (from Supabase → Settings → API → Project API Keys → service_role)
# ⚠️  This is a SECRET key — never expose in frontend code
# Used ONLY in Netlify serverless functions (register-tenant, invite-user)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...your-service-role-key

# App URL (your Netlify site URL — used for email redirects)
VITE_APP_URL=https://nexora-survey.netlify.app
